{
  "version": 3,
  "framework": {
    "name": "nitro",
    "version": "3.0.260522-beta"
  },
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/assets/(.*)"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://oc-pro-production.up.railway.app/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/__server"
    }
  ]
}